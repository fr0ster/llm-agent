# OpenAI settings
OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions
OPENAI_API_KEY=
OPENAI_ORG=
OPENAI_PRJ=
OPENAI_PROJECT=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude) settings
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# DeepSeek settings
DEEPSEEK_ENDPOINT=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Ollama settings
OLLAMA_ENDPOINT=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=llama3.2

# SAP AI SDK settings (via @sap-ai-sdk/orchestration)
# AICORE_SERVICE_KEY is read automatically by the SDK (JSON service key from BTP)
AICORE_SERVICE_KEY=
SAP_AI_MODEL=gpt-4o
SAP_AI_RESOURCE_GROUP=

# LLM Provider selection
# Options: openai, anthropic, deepseek, ollama, sap-ai-sdk
LLM_PROVIDER=openai

# MCP Configuration
MCP_ENDPOINT=http://localhost:4004/mcp/stream/http
MCP_DISABLED=false
MCP_AUTH_HEADER=Basic YWxpY2U6
SAP_DESTINATION=

# Debug settings
DEBUG_LLM_REASON=false
