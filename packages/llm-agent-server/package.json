{
  "name": "@mcp-abap-adt/llm-agent-server",
  "version": "20.2.0",
  "description": "Default SmartAgent implementation with LLM providers, MCP client, HTTP server, and CLI.",
  "type": "module",
  "bin": {
    "llm-agent": "bin/llm-agent",
    "llm-agent-check": "bin/llm-agent-check",
    "claude-via-agent": "tools/claude-via-agent.sh"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "tools",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "tsc -p tsconfig.json --clean",
    "test": "node --import tsx/esm --test --test-reporter=spec 'src/**/*.test.ts'",
    "test:adapters": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/adapters/__tests__/llm-adapter.test.ts",
    "test:server": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/__tests__/server.test.ts",
    "smoke:adapters": "tsx src/smoke-adapters.ts",
    "start": "node dist/smart-agent/cli.js",
    "start:smart": "node dist/smart-agent/cli.js --config smart-server.yaml",
    "dev": "tsx src/smart-agent/cli.ts",
    "release:check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mcp-abap-adt/anthropic-llm": "^20.2.0",
    "@mcp-abap-adt/deepseek-llm": "^20.2.0",
    "@mcp-abap-adt/hana-vector-rag": "^20.2.0",
    "@mcp-abap-adt/llm-agent": "^20.2.0",
    "@mcp-abap-adt/llm-agent-libs": "^20.2.0",
    "@mcp-abap-adt/llm-agent-mcp": "^20.2.0",
    "@mcp-abap-adt/llm-agent-rag": "^20.2.0",
    "@mcp-abap-adt/llm-agent-server-libs": "^20.2.0",
    "@mcp-abap-adt/ollama-embedder": "^20.2.0",
    "@mcp-abap-adt/ollama-llm": "^20.2.0",
    "@mcp-abap-adt/openai-embedder": "^20.2.0",
    "@mcp-abap-adt/openai-llm": "^20.2.0",
    "@mcp-abap-adt/pg-vector-rag": "^20.2.0",
    "@mcp-abap-adt/qdrant-rag": "^20.2.0",
    "@mcp-abap-adt/sap-aicore-embedder": "^20.2.0",
    "@mcp-abap-adt/sap-aicore-llm": "^20.2.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "dotenv": "^17.3.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mcp-abap-adt/anthropic-llm": "^20.2.0",
    "@mcp-abap-adt/deepseek-llm": "^20.2.0",
    "@mcp-abap-adt/hana-vector-rag": "^20.2.0",
    "@mcp-abap-adt/ollama-embedder": "^20.2.0",
    "@mcp-abap-adt/openai-embedder": "^20.2.0",
    "@mcp-abap-adt/openai-llm": "^20.2.0",
    "@mcp-abap-adt/pg-vector-rag": "^20.2.0",
    "@mcp-abap-adt/qdrant-rag": "^20.2.0",
    "@mcp-abap-adt/sap-aicore-embedder": "^20.2.0",
    "@mcp-abap-adt/sap-aicore-llm": "^20.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@sap-ai-sdk/ai-api": "^2.11.0",
    "@sap-ai-sdk/orchestration": "^2.11.0",
    "@types/node": "^25.9.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fr0ster/llm-agent.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
