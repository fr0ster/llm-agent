{
  "name": "@cloud-llm-hub/llm-agent",
  "version": "0.1.0",
  "description": "Minimal LLM agent orchestrating MCP tools across multiple LLM providers.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "dev:llm": "tsx src/cli.ts --llm-only",
    "start": "node dist/cli.js",
    "start:llm": "node dist/cli.js --llm-only",
    "test": "npm run build && npm start",
    "test:llm": "npm run build && npm run start:llm",
    "clean": "rimraf dist || rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.2",
    "axios": "^1.7.7",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4",
    "typescript": "^5"
  },
  "license": "MIT",
  "private": true
}
