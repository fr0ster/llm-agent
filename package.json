{
  "name": "@mcp-abap-adt/llm-agent",
  "version": "5.18.0",
  "description": "Core components for building Smart LLM agents, plus a default MCP-orchestrated OpenAI-compatible server implementation.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/smart-agent/testing/index.d.ts",
      "import": "./dist/smart-agent/testing/index.js",
      "default": "./dist/smart-agent/testing/index.js"
    },
    "./smart-server": {
      "types": "./dist/smart-agent/smart-server.d.ts",
      "import": "./dist/smart-agent/smart-server.js",
      "default": "./dist/smart-agent/smart-server.js"
    },
    "./otel": {
      "types": "./dist/smart-agent/otel/index.d.ts",
      "import": "./dist/smart-agent/otel/index.js",
      "default": "./dist/smart-agent/otel/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node scripts/generate-version.js",
    "build": "tsc -p tsconfig.json",
    "smoke:adapters": "tsx src/smoke-adapters.ts",
    "test:adapters": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/adapters/__tests__/llm-adapter.test.ts src/smart-agent/adapters/__tests__/mcp-client-adapter.test.ts",
    "test:server": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/__tests__/server.test.ts",
    "test:logger": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/logger/__tests__/logger.test.ts",
    "test:policy": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/policy/__tests__/tool-policy-guard.test.ts src/smart-agent/policy/__tests__/heuristic-injection-detector.test.ts src/smart-agent/policy/__tests__/tool-availability-registry.test.ts",
    "test:regression": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/__tests__/regression.test.ts",
    "test:tracer": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/tracer/__tests__/tracer.test.ts",
    "test:rag-eval": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/rag/__tests__/rag-evaluation.test.ts",
    "test:metrics": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/metrics/__tests__/metrics.test.ts",
    "test:resilience": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/resilience/__tests__/circuit-breaker.test.ts src/smart-agent/resilience/__tests__/circuit-breaker-llm.test.ts src/smart-agent/resilience/__tests__/fallback-rag.test.ts",
    "test:health": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/health/__tests__/health-checker.test.ts",
    "test:config-watcher": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/config/__tests__/config-watcher.test.ts",
    "test:reranker": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/reranker/__tests__/reranker.test.ts",
    "test:inverted-index": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/rag/__tests__/inverted-index.test.ts",
    "test:query-expander": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/rag/__tests__/query-expander.test.ts",
    "test:qdrant": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/rag/__tests__/qdrant-rag.test.ts",
    "test:cache": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/cache/__tests__/tool-cache.test.ts",
    "test:validator": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/validator/__tests__/validator.test.ts",
    "test:session": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/session/__tests__/session-manager.test.ts",
    "test:classifier-bench": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/classifier/__tests__/classifier-benchmark.test.ts",
    "test:providers": "node --import tsx/esm --test --test-reporter=spec src/llm-providers/__tests__/openai.test.ts src/llm-providers/__tests__/anthropic.test.ts src/llm-providers/__tests__/deepseek.test.ts src/llm-providers/__tests__/sap-core-ai.test.ts",
    "test:agents": "node --import tsx/esm --test --test-reporter=spec src/agents/__tests__/sap-core-ai-agent.test.ts",
    "test:lazy": "node --import tsx/esm --test --test-reporter=spec src/smart-agent/utils/__tests__/lazy.test.ts",
    "test:all": "npm run test:adapters && npm run test:server && npm run test:logger && npm run test:policy && npm run test:regression && npm run test:tracer && npm run test:rag-eval && npm run test:metrics && npm run test:resilience && npm run test:health && npm run test:config-watcher && npm run test:reranker && npm run test:inverted-index && npm run test:query-expander && npm run test:qdrant && npm run test:cache && npm run test:validator && npm run test:session && npm run test:classifier-bench && npm run test:providers && npm run test:agents && npm run test:lazy",
    "release:check": "npm run lint:check && npm run build && npm run test:all",
    "start": "node dist/smart-agent/cli.js",
    "start:smart": "npm run start",
    "start:llm": "node dist/cli.js --llm-only",
    "dev": "tsx src/smart-agent/cli.ts",
    "dev:llm": "tsx src/cli.ts --llm-only",
    "client:test-stream": "node --import tsx/esm scripts/test-stream-client.ts",
    "client:text": "node --import tsx/esm scripts/text-client.ts",
    "test": "npm run build && npm run start",
    "test:llm": "npm run build && npm run start:llm",
    "lint": "npx biome check --write --config-path . src",
    "lint:check": "npx biome check --config-path . src",
    "format": "npx biome format --write --config-path . src",
    "clean": "rimraf dist || rm -rf dist",
    "publish:beta": "npm run release:check && npm publish --tag beta",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@sap-ai-sdk/orchestration": "^2.9.0",
    "axios": "^1.14.0",
    "dotenv": "^17.3.1",
    "yaml": "^2.8.3"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@sap-ai-sdk/ai-api": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "@sap-ai-sdk/ai-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@opentelemetry/api": "^1.9.0",
    "@sap-ai-sdk/ai-api": "^2.7.0",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "bin": {
    "llm-agent": "./dist/smart-agent/cli.js",
    "llm-agent-check": "./dist/smart-agent/check-models-cli.js",
    "claude-via-agent": "./tools/claude-via-agent.sh"
  },
  "license": "MIT",
  "author": "Oleksii Kyslytsia <oleksij.kyslytsja@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fr0ster/llm-agent.git"
  },
  "keywords": [
    "llm",
    "agent",
    "mcp",
    "model-context-protocol",
    "sap-ai-core"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
