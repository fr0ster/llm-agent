# examples/docker-sap-ai-core — SAP AI Core LLM (orchestration) + SAP AI Core embedder (foundation-models).
# Copy this to `.env` and paste your AICORE_SERVICE_KEY JSON.

# --- SAP AI Core authentication ---------------------------------------------

# Single JSON blob copied verbatim from the BTP Service Key page.
# Required keys: clientid, clientsecret, url, serviceurls.AI_API_URL.
AICORE_SERVICE_KEY={"clientid":"sb-...","clientsecret":"...","url":"https://....authentication.eu10.hana.ondemand.com","serviceurls":{"AI_API_URL":"https://api.ai.prod.eu-central-1.aws.ml.hana.ondemand.com"}}

# --- LLM (chat) — must be deployed under the orchestration scenario ----------

LLM_PROVIDER=sap-ai-sdk
LLM_MODEL_NAME=anthropic--claude-4.6-sonnet
LLM_CLASSIFIER_MODEL=anthropic--claude-3-haiku
LLM_HELPER_MODEL=anthropic--claude-3-haiku

# --- Embeddings — model deployed under the foundation-models scenario --------

# `sap-ai-core` is the embedder factory name (alias `sap-aicore` also accepted).
RAG_EMBEDDER=sap-ai-core
# `foundation-models` (default) calls the AI Core REST inference API directly.
# Use `orchestration` only if your embedding model is deployed under that scenario.
RAG_SCENARIO=foundation-models
RAG_RESOURCE_GROUP=default
# Pick a model your tenant has deployed under foundation-models, e.g.:
#   text-embedding-3-small (Azure OpenAI family, 1536-dim)
#   gemini-embedding (Vertex AI family, 3072-dim)
# NOTE: Qdrant collection names auto-suffix with this value, so swapping
# embedders does not collide on incompatible vector dimensions — each
# embedder lives in its own collection (e.g. mcp_tools__gemini-embedding).
EMBEDDING_MODEL=text-embedding-3-small

# --- Backend services -------------------------------------------------------

# RAG store type. Default `in-memory` (no external service) for `npm run dev:sap-ai-core`.
# Override to `qdrant` (and start Qdrant) for persistence and the docker-compose recipe:
#   docker run -p 6333:6333 qdrant/qdrant
# RAG_TYPE=qdrant
QDRANT_URL=http://localhost:6333

# Local MCP server.
MCP_SERVER_URL=http://localhost:3001/mcp/stream/http

# --- Optional ---------------------------------------------------------------

# PORT=4004
# SKILLS_DIR=./skills
# LOG_DIR=./sessions
